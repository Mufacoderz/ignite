generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USER ====================
model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String?
  googleId   String?  @unique
  avatar     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  exercises  Exercise[]
  plans      Plan[]
  dailyLogs  DailyLog[]
}

// ==================== EXERCISE ====================
enum ExerciseCategory {
  STRENGTH
  CARDIO
  BALANCE
  FLEXIBILITY
}

enum ExerciseType {
  REPS_BASED
  TIME_BASED
}

model Exercise {
  id              String           @id @default(cuid())
  userId          String
  name            String
  category        ExerciseCategory
  type            ExerciseType
  reps            Int?
  sets            Int?
  durationSeconds Int?
  timeSets        Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  planItems PlanItem[]
  logItems  DailyLogItem[]
}

// ==================== PLAN ====================
model Plan {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items PlanItem[]
}

model PlanItem {
  id         String   @id @default(cuid())
  planId     String
  exerciseId String
  order      Int

  plan     Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

// ==================== DAILY LOG ====================
model DailyLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items DailyLogItem[]

  @@unique([userId, date])
}

model DailyLogItem {
  id         String   @id @default(cuid())
  dailyLogId String
  exerciseId String
  isChecked  Boolean  @default(false)
  order      Int
  source     String

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}